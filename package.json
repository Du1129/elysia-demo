{
  "name": "elysia-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "debug": "bun --inspect-wait=localhost:6499 src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@elysia/cors": "^1.4.2",
    "@elysia/cron": "^1.4.2",
    "@elysia/jwt": "^1.4.2",
    "@elysia/openapi": "^1.4.15",
    "@sinclair/typebox": "0.34.8",
    "bullmq": "^5.79.3",
    "dayjs": "^1.11.21",
    "drizzle-orm": "^0.45.2",
    "drizzle-typebox": "^0.3.3",
    "elysia": "latest",
    "nodemailer": "^9.0.3",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "qiniu": "^7.15.2",
    "redis": "^6.1.0",
    "svg-captcha": "^1.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^8.0.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "latest"
  },
  "overrides": {
    "@sinclair/typebox": "0.34.8"
  }
}
